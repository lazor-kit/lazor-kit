{
  "name": "@lazorkit/wallet",
  "version": "1.4.1",
  "description": "Lazorkit Wallet SDK for Solana",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@coral-xyz/anchor": "catalog:",
    "@solana/web3.js": "catalog:",
    "bs58": "^6.0.0",
    "eventemitter3": "^5.0.1",
    "js-sha256": "^0.11.0",
    "zustand": "^5.0.5"
  },
  "peerDependencies": {
    "react": "^18.3.1 || ^19.0.0",
    "react-dom": "^18.3.1 || ^19.0.0"
  },
  "devDependencies": {
    "@types/bs58": "^5.0.0",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
